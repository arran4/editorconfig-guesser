Svelte with 2 spaces
-- index.svelte --
<script>
  let count = 0;
  function increment() {
    count += 1;
    if (count > 10) {
      count = 0;
    }
  }
</script>

<div>
  <span>
    {count}
  </span>
  <button on:click={increment}>
    Increment
  </button>
</div>
-- expected.editorconfig --
